<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"><title>Cúc Cúc Cúc - Sử Việt</title><script src="https://cdn.tailwindcss.com"></script><style>@import url('https://fonts.googleapis.com/css2?family=Bungee&family=Inter:wght@400;700&family=Noto+Serif+JP:wght@700&display=swap');:root{--card-width:65px;--card-height:110px;--overlap-spacing:38px}body{background-color:#020617;color:white;font-family:'Inter',sans-serif;overflow:hidden;touch-action:none}.pixel-font{font-family:'Bungee',cursive}.han-font{font-family:'Noto Serif JP',serif}.card{width:var(--card-width);height:var(--card-height);border-radius:8px;position:relative;flex-shrink:0;transition:all 0.25s cubic-bezier(0.175,0.885,0.32,1.275);user-select:none}.card-fallback{background:#fffcf0;color:#1a1a1a;border:2px solid #ddd;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 2px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.3)}.card-red{border-color:#ef4444;background:#fff5f5;color:#b91c1c}.card-black{border-color:#374151;background:#f3f4f6;color:#111827}.hand-container{display:flex;justify-content:center;width:100%;height:140px;padding:10px 20px;position:relative;margin-top:5px}.hand-card-wrapper{position:absolute;transition:all 0.3s ease}.card.selected{transform:translateY(-40px)!important;z-index:100!important;border:3px solid #facc15;box-shadow:0 0 20px rgba(250,204,21,0.6)}.nav-glass{background:rgba(15,23,42,0.9);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.1)}.era-badge{background:linear-gradient(90deg,#991b1b,#450a0a);padding:4px 12px;border-radius:4px;font-size:10px;border:1px solid #f87171;box-shadow:0 0 10px rgba(239,68,68,0.2);text-align:center}.modal-bg{background:rgba(0,0,0,0.95);backdrop-filter:blur(12px)}.general-card{background:linear-gradient(145deg,#1e293b,#0f172a);border:2px solid #334155;transition:all 0.3s}.general-card.selected-general{border-color:#eab308;box-shadow:0 0 15px rgba(234,179,8,0.4);transform:scale(1.05)}.buff-text{font-size:9px;color:#4ade80;margin-top:2px;font-weight:bold}.han-center{position:absolute;top:55%;left:50%;transform:translate(-50%,-40%);opacity:0.15;font-size:3.2rem;pointer-events:none}.strategy-box{background:linear-gradient(to right,rgba(30,58,138,0.4),rgba(15,23,42,0.2));border-left:4px solid #eab308;padding:10px 14px;border-radius:4px 12px 12px 4px;margin:4px 16px;box-shadow:4px 4px 15px rgba(0,0,0,0.3)}.strategy-title{color:#facc15;font-family:'Bungee',cursive;font-size:11px;letter-spacing:1px}@keyframes titleGlow{0%,100%{text-shadow:0 0 10px #facc15,0 0 20px #eab308}50%{text-shadow:0 0 20px #facc15,0 0 40px #eab308,0 0 60px #b45309}}.title-glow{animation:titleGlow 3s infinite}.menu-btn{background:linear-gradient(180deg,#1e293b 0%,#0f172a 100%);border:1px solid #334155;box-shadow:0 4px 0 #020617;transition:all 0.1s}.menu-btn:active{transform:translateY(2px);box-shadow:0 2px 0 #020617}</style></head><body class="flex flex-col h-screen overflow-hidden bg-slate-950 text-white"><div id="start-menu" class="fixed inset-0 z-[300] bg-slate-950 flex flex-col items-center justify-between py-16 px-8"><div class="text-center"><div class="text-red-600 han-font text-6xl mb-2 opacity-50">帥</div><h1 class="text-4xl font-bold pixel-font text-yellow-500 title-glow leading-none">CÚC CÚC CÚC</h1><p class="text-xl font-bold pixel-font text-white tracking-widest mt-2">SỬ VIỆT</p><div class="h-1 w-24 bg-red-600 mx-auto mt-4 rounded-full"></div><p class="text-[10px] text-slate-400 mt-4 tracking-[0.3em] font-bold uppercase">Tác giả: LongLT</p></div><div class="w-full max-w-xs space-y-3"><button onclick="ui.startGame()" class="w-full py-4 bg-yellow-500 text-black font-black pixel-font text-xl rounded-xl shadow-[0_6px_0_#a16207] active:shadow-none active:translate-y-1 transition-all mb-2">BẮT ĐẦU</button><button onclick="ui.showCollection('combos')" class="menu-btn w-full py-3 text-sm font-bold uppercase tracking-widest rounded-xl text-yellow-500">TỔ HỢP BÀI</button><button onclick="ui.showCollection('generals')" class="menu-btn w-full py-3 text-sm font-bold uppercase tracking-widest rounded-xl">DANH TƯỚNG</button><button onclick="ui.showCollection('skills')" class="menu-btn w-full py-3 text-sm font-bold uppercase tracking-widest rounded-xl">KẾ SÁCH</button></div><div class="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Ver 1.5.0 • Tam Cúc Roguelike</div></div><div id="collection-modal" class="fixed inset-0 z-[400] modal-bg p-6 overflow-y-auto hidden"><div class="flex justify-between items-center mb-6"><h2 id="collection-title" class="text-2xl font-bold pixel-font text-yellow-500">DANH SÁCH</h2><button onclick="ui.closeCollection()" class="w-10 h-10 bg-red-900/50 rounded-full flex items-center justify-center border border-red-500 text-red-500 font-bold">X</button></div><div id="collection-content" class="grid grid-cols-1 gap-4 pb-12"></div></div><div id="general-selection" class="fixed inset-0 z-[200] modal-bg flex flex-col items-center p-6 overflow-y-auto hidden"><div class="text-center mb-6"><h1 class="text-2xl font-bold pixel-font text-yellow-500 leading-tight">DANH TƯỚNG PHÒ TÁ</h1><p id="selection-era-name" class="text-blue-400 text-xs uppercase font-bold mt-1 tracking-widest"></p></div><div id="generals-list" class="grid grid-cols-1 gap-4 w-full max-w-md"></div><button id="start-round-btn" class="mt-8 mb-8 w-full max-w-md bg-yellow-500 text-black font-black py-4 rounded-xl text-xl opacity-50 cursor-not-allowed transition-all" disabled>XUẤT QUÂN</button></div><div class="nav-glass p-3 grid grid-cols-4 gap-2 items-center"><div class="flex flex-col"><span class="text-[10px] text-slate-400 uppercase font-bold">Mục tiêu</span><span id="target-score" class="text-blue-400 font-bold pixel-font text-xs leading-tight">0</span></div><div class="flex flex-col items-center col-span-1"><span class="text-[10px] text-slate-400 uppercase font-bold">Chiến tích</span><span id="current-score" class="text-yellow-400 font-bold pixel-font text-base leading-tight">0</span></div><div class="col-span-2 flex justify-end gap-1.5 text-[9px]"><div class="bg-slate-800 rounded px-1.5 py-1 text-center min-w-[38px]"><div class="text-slate-400 font-bold uppercase text-[8px]">Bài</div><div id="deck-left" class="text-xs font-bold text-white">32</div></div><div class="bg-slate-800 rounded px-1.5 py-1 text-center min-w-[38px]"><div class="text-red-400 font-bold uppercase text-[8px]">Lương</div><div id="hands-left" class="text-xs font-bold">4</div></div><div class="bg-slate-800 rounded px-1.5 py-1 text-center min-w-[42px]"><div class="text-green-400 font-bold uppercase text-[8px]">T.Thần</div><div id="discards-left" class="text-xs font-bold">3</div></div></div></div><div class="w-full flex items-center px-4 py-2 bg-slate-900/30 gap-3 border-b border-white/5"><div id="era-name-display" class="era-badge pixel-font text-[8px] uppercase leading-tight whitespace-nowrap">Khởi đầu</div><div class="flex items-center gap-1.5 overflow-hidden"><span class="text-[9px] text-yellow-500 font-black uppercase italic">Tướng:</span><span id="active-general-name-label" class="text-white text-[10px] font-bold truncate tracking-wide">Chưa chọn</span></div></div><div class="strategy-box"><div class="flex justify-between items-center mb-1"><span class="text-[9px] text-blue-400 font-bold uppercase tracking-widest">Kế sách thi triển:</span><span id="strategy-name" class="strategy-title">---</span></div><div id="strategy-desc" class="text-white/80 text-[10px] italic leading-snug border-t border-white/10 pt-1">Chưa có kế sách nào được thi triển.</div></div><div id="play-area" class="flex-1 flex flex-col items-center justify-center relative"><div id="hand-name-container" class="absolute top-2 text-center z-10 opacity-0 transition-all transform -translate-y-2"><div id="hand-name" class="text-yellow-400 font-bold pixel-font text-lg leading-tight">---</div><div id="potential-score-badge" class="mt-1 px-3 py-0.5 rounded-full text-[10px] bg-black/60 border border-yellow-500/50 flex flex-col items-center justify-center backdrop-blur-sm"><div class="flex items-center gap-1.5"><span id="potential-chips" class="text-blue-400 font-bold">0</span><span class="text-white/40">×</span><span id="potential-mult" class="text-red-400 font-bold">0</span><span class="text-white/40">=</span><span id="potential-total" class="text-yellow-400 font-bold">0</span></div><div id="buff-detail" class="buff-text hidden"></div></div></div><div id="selected-area" class="flex gap-1 h-32 items-center justify-center"></div></div><div class="w-full pb-6 pt-2 bg-slate-950/80 backdrop-blur-sm"><div id="player-hand" class="hand-container"></div><div class="flex justify-center gap-4 mt-2 px-6"><button id="btn-discard" class="flex-1 bg-slate-800 border-2 border-red-500/50 text-red-400 py-3 rounded-xl font-bold uppercase text-xs disabled:opacity-30">Chấn chỉnh</button><button id="btn-play" class="flex-[1.5] bg-blue-600 border-b-4 border-blue-800 text-white py-3 rounded-xl font-bold uppercase text-xs active:translate-y-1 active:border-b-0 disabled:opacity-30">Xuất quân</button></div></div><div id="msg-overlay" class="fixed inset-0 bg-black/95 z-[100] flex flex-col items-center justify-center p-6 hidden text-center"><h2 id="msg-title" class="text-4xl font-bold pixel-font mb-2"></h2><p id="msg-desc" class="text-slate-400 mb-8"></p><button id="msg-continue-btn" class="w-full max-w-xs bg-yellow-500 text-black font-black py-4 rounded-2xl text-xl uppercase">Tiếp tục</button></div><script>const CARD_DATA=[{name:'Tướng',rank:10,count:1,han:{red:'帥',black:'將'}},{name:'Sĩ',rank:8,count:2,han:{red:'仕',black:'士'}},{name:'Tượng',rank:7,count:2,han:{red:'相',black:'象'}},{name:'Xe',rank:6,count:2,han:{red:'俥',black:'車'}},{name:'Pháo',rank:5,count:2,han:{red:'炮',black:'砲'}},{name:'Mã',rank:4,count:2,han:{red:'傌',black:'馬'}},{name:'Tốt',rank:2,count:5,han:{red:'兵',black:'卒'}}];const HAND_COMBOS=[{name:'QUÂN LẺ',desc:'Các quân bài không tạo thành bộ.',baseChips:'Tổng Rank x 5',baseMult:1},{name:'BỘ ĐÔI',desc:'2 quân bài cùng tên (Ví dụ: 2 Pháo).',baseChips:40,baseMult:2},{name:'ĐÔI TƯỚNG',desc:'Bộ đôi gồm Tướng đỏ và Tướng đen.',baseChips:200,baseMult:6},{name:'XE PHÁO MÃ',desc:'Bộ ba gồm 1 Xe, 1 Pháo, 1 Mã cùng màu.',baseChips:120,baseMult:3},{name:'BỘ BA',desc:'3 quân bài cùng tên (Ví dụ: 3 Tốt).',baseChips:150,baseMult:4},{name:'TỨ QUÝ',desc:'4 quân bài cùng tên.',baseChips:300,baseMult:8},{name:'NGŨ TỬ',desc:'Bộ 5 quân Tốt cùng màu.',baseChips:400,baseMult:12}];const STRATEGIES=[{name:"Dương đông kích tây",desc:"Đánh lạc hướng địch: Quân bài có bậc thấp nhất nhận x3 Mult."},{name:"Vây Ngụy cứu Triệu",desc:"Đánh vào điểm yếu: Bộ 'NGŨ TỬ' hoặc 'TỨ QUÝ' nhận thêm +200 Chips."},{name:"Mượn đao giết người",desc:"Tận dụng sức địch: Mỗi quân bài ĐEN trong bộ nhận thêm +25 Chips."},{name:"Tiên phát chế nhân",desc:"Ra tay trước: Lượt đánh đầu tiên của mỗi vòng được x2 tổng điểm."},{name:"Thuyền cỏ mượn tên",desc:"Thu gom vũ khí: Mỗi quân 'TỐT' đánh ra nhận thêm +15 Chips."},{name:"Điệu hổ ly sơn",desc:"Dụ địch ra xa: Nếu bộ chỉ có 1 quân, nhận x4 Mult."}];const ERAS=[{name:"Thời Hai Bà Trưng",target:500,generals:[{id:'trung_trac',name:"Trưng Trắc",era:"Hai Bà Trưng",desc:"Bộ có 'TỐT' nhận +60 Chips.",strategy:STRATEGIES[0],buff:(combo,cards)=>cards.some(c=>c.name==='Tốt')?{chipsAdd:60,label:"+60 Tốt (Trưng Trắc)"}:{}},{id:'le_chan',name:"Lê Chân",era:"Hai Bà Trưng",desc:"Quân 'SĨ' nhận x2 Mult.",strategy:STRATEGIES[1],check:(cards)=>cards.some(c=>c.name==='Sĩ')?{mult:2,label:"x2 Sĩ (Lê Chân)"}:null}]},{name:"Thời Ngô Quyền",target:2000,generals:[{id:'ngo_quyen',name:"Ngô Quyền",era:"Ngô Quyền",desc:"Bộ 'XE PHÁO MÃ' nhận x3 Mult.",strategy:STRATEGIES[3],buff:(combo)=>combo.name==='XE PHÁO MÃ'?{multAdd:2,label:"x3 XE PHÁO MÃ"}:{}},{id:'duong_dinh_nghe',name:"Dương Đình Nghệ",era:"Ngô Quyền",desc:"+1 lượt Chấn chỉnh mỗi vòng.",strategy:STRATEGIES[4],onStartRound:()=>bonusDiscards+=1}]},{name:"Thời Đinh - Tiền Lê",target:6000,generals:[{id:'dinh_bo_linh',name:"Đinh Bộ Lĩnh",era:"Đinh - Tiền Lê",desc:"Bộ 'BỘ ĐÔI' nhận +100 Chips.",strategy:STRATEGIES[2],buff:(combo)=>combo.name.includes('ĐÔI')?{chipsAdd:100,label:"+100 Đôi (Hoa Lư)"}:{}},{id:'le_hoan',name:"Lê Hoàn",era:"Đinh - Tiền Lê",desc:"Nếu thắng với <2 lượt Lương, nhận x5 Mult.",strategy:STRATEGIES[0],buff:(combo)=>hands<=1?{multAdd:4,label:"x5 Hào khí (Lê Hoàn)"}:{}}]},{name:"Thời Lý",target:15000,generals:[{id:'ly_thuong_kiet',name:"Lý Thường Kiệt",era:"Lý",desc:"Quân 'TƯỢNG' nhận x4 Mult.",strategy:STRATEGIES[3],check:(cards)=>cards.some(c=>c.name==='Tượng')?{mult:4,label:"x4 Tượng (Lý Thường Kiệt)"}:null},{id:'ly_thai_to',name:"Lý Thái Tổ",era:"Lý",desc:"Mỗi quân ĐỎ nhận +20 Chips.",strategy:STRATEGIES[4],buff:(combo,cards)=>{let sum=0;cards.forEach(c=>{if(c.suit==='red')sum+=20;});return{chipsAdd:sum,label:`+${sum} Đỏ (Lý Thái Tổ)`};}}]},{name:"Thời Trần",target:40000,generals:[{id:'tran_hung_dao',name:"Trần Hưng Đạo",era:"Trần",desc:"Quân 'TƯỚNG' nhận x10 Mult.",strategy:STRATEGIES[2],check:(cards)=>cards.some(c=>c.name==='Tướng')?{mult:10,label:"x10 Tướng (Trần Hưng Đạo)"}:null},{id:'tran_khan_du',name:"Trần Khánh Dư",era:"Trần",desc:"Bộ QUÂN LẺ nhận x3 Chips, x2 Mult.",strategy:STRATEGIES[5],buff:(combo)=>combo.name==='QUÂN LẺ'?{chipsAdd:combo.chips*2,multAdd:1,label:"Vân Đồn x3/x2"}:{}}]},{name:"Thời Lê Sơ",target:100000,generals:[{id:'le_loi',name:"Lê Lợi",era:"Lê Sơ",desc:"Bộ 'NGŨ TỬ' nhận +500 Chips, x10 Mult.",strategy:STRATEGIES[1],buff:(combo)=>combo.name==='NGŨ TỬ'?{chipsAdd:500,multAdd:9,label:"Lam Sơn Đại Thắng"}:{}},{id:'nguyen_trai',name:"Nguyễn Trãi",era:"Lê Sơ",desc:"Lượt Chấn chỉnh dư x2 Mult.",strategy:STRATEGIES[4],buff:()=>({multAdd:Math.max(0,discards),label:`x${discards+1} Tinh thần`})}]}];let deck=[],hand=[],selected=[],score=0,currentEraIdx=0;let hands=4,discards=3,bonusHands=0,bonusDiscards=0;let selectedGeneral=null,gameWon=false;const ui={startGame:()=>{currentEraIdx=0;document.getElementById('start-menu').classList.add('hidden');showGeneralSelection();},showCollection:(type)=>{const modal=document.getElementById('collection-modal');const content=document.getElementById('collection-content');const title=document.getElementById('collection-title');modal.classList.remove('hidden');content.innerHTML='';if(type==='generals'){title.innerText="DANH TƯỚNG";ERAS.forEach(era=>{const eraHeader=document.createElement('div');eraHeader.className="text-blue-400 font-bold text-xs mt-4 uppercase border-b border-blue-900 pb-1";eraHeader.innerText=era.name;content.appendChild(eraHeader);era.generals.forEach(gen=>{const div=document.createElement('div');div.className="general-card p-4 rounded-xl mt-2";div.innerHTML=`<div class="flex justify-between items-center"><span class="text-yellow-500 font-bold">${gen.name}</span></div><p class="text-[10px] text-slate-400 mt-1 italic">${gen.desc}</p>`;content.appendChild(div);});});}else if(type==='combos'){title.innerText="TỔ HỢP BÀI";HAND_COMBOS.forEach(combo=>{const div=document.createElement('div');div.className="bg-slate-900 border border-slate-800 p-4 rounded-xl mt-2";div.innerHTML=`<div class="flex justify-between items-start mb-1"><span class="text-yellow-500 font-bold pixel-font text-sm uppercase">${combo.name}</span><div class="text-[10px] flex gap-2"><span class="text-blue-400 font-bold">${combo.baseChips}</span><span class="text-slate-500">×</span><span class="text-red-400 font-bold">${combo.baseMult}</span></div></div><p class="text-[10px] text-slate-400 italic">${combo.desc}</p>`;content.appendChild(div);});}else{title.innerText="KẾ SÁCH";STRATEGIES.forEach(s=>{const div=document.createElement('div');div.className="bg-slate-900 border border-slate-800 p-4 rounded-xl mt-2";div.innerHTML=`<div class="text-yellow-500 font-bold text-sm mb-1 uppercase">${s.name}</div><p class="text-[10px] text-slate-400">${s.desc}</p>`;content.appendChild(div);});}},closeCollection:()=>document.getElementById('collection-modal').classList.add('hidden')};function initDeck(){deck=[];['red','black'].forEach(suit=>{CARD_DATA.forEach(c=>{for(let i=0;i<c.count;i++)deck.push({...c,suit,id:Math.random()});});});deck.sort(()=>Math.random()-0.5);}function drawCards(){while(hand.length<8&&deck.length>0)hand.push(deck.pop());}function showGeneralSelection(){const era=ERAS[currentEraIdx];document.getElementById('selection-era-name').innerText=era.name;const list=document.getElementById('generals-list');list.innerHTML='';const availableGenerals=[];for(let i=0;i<=currentEraIdx;i++)ERAS[i].generals.forEach(g=>availableGenerals.push(g));availableGenerals.reverse().forEach(gen=>{const div=document.createElement('div');div.className='general-card p-4 rounded-xl cursor-pointer border-2 border-transparent transition-all';div.innerHTML=`<div class="flex justify-between"><div><h3 class="text-yellow-400 font-bold">${gen.name}</h3><span class="text-[7px] text-slate-500 uppercase font-black">${gen.era}</span></div></div><p class="text-[10px] text-slate-400 mt-2">${gen.desc}</p>`;div.onclick=()=>{document.querySelectorAll('.general-card').forEach(c=>c.classList.remove('selected-general'));div.classList.add('selected-general');selectedGeneral=gen;document.getElementById('start-round-btn').disabled=false;document.getElementById('start-round-btn').classList.remove('opacity-50');};list.appendChild(div);});document.getElementById('general-selection').classList.remove('hidden');}function startNewRound(){score=0;hands=4;discards=3;bonusHands=0;bonusDiscards=0;if(selectedGeneral&&selectedGeneral.onStartRound)selectedGeneral.onStartRound();hands+=bonusHands;discards+=bonusDiscards;document.getElementById('active-general-name-label').innerText=selectedGeneral.name;document.getElementById('strategy-name').innerText=selectedGeneral.strategy.name;document.getElementById('strategy-desc').innerText=selectedGeneral.strategy.desc;initDeck();hand=[];drawCards();selected=[];render();}function render(){const era=ERAS[currentEraIdx];document.getElementById('era-name-display').innerText=era.name;const handEl=document.getElementById('player-hand');handEl.innerHTML='';const totalCards=hand.length;const overlapWidth=38;const totalWidth=(totalCards-1)*overlapWidth+65;const startLeft=`calc(50% - ${totalWidth/2}px)`;hand.forEach((card,i)=>{const wrapper=document.createElement('div');wrapper.className='hand-card-wrapper';const isSelected=selected.includes(i);const hanChar=card.suit==='red'?card.han.red:card.han.black;wrapper.style.left=`calc(${startLeft} + ${i*overlapWidth}px)`;wrapper.style.zIndex=i+1;wrapper.innerHTML=`<div class="card card-fallback ${card.suit==='red'?'card-red':'card-black'} ${isSelected?'selected':''}"><div class="text-[9px] absolute top-1 left-1 opacity-40 font-bold">${card.rank}</div><div class="text-[10px] font-bold absolute top-1 right-1 opacity-60">${card.name}</div><div class="han-font han-center">${hanChar}</div></div>`;wrapper.onclick=()=>{const p=selected.indexOf(i);if(p>-1)selected.splice(p,1);else if(selected.length<5)selected.push(i);render();};handEl.appendChild(wrapper);});const selArea=document.getElementById('selected-area');selArea.innerHTML='';selected.forEach(idx=>{const c=hand[idx];const hanChar=c.suit==='red'?c.han.red:c.han.black;const el=document.createElement('div');el.className=`card card-fallback ${c.suit==='red'?'card-red':'card-black'} scale-75 shadow-xl`;el.innerHTML=`<div class="text-[10px] font-bold absolute top-1 right-1 opacity-60">${c.name}</div><div class="han-font han-center" style="font-size:2.5rem">${hanChar}</div>`;selArea.appendChild(el);});const comboResult=calculateCombo();const handContainer=document.getElementById('hand-name-container');document.getElementById('hand-name').innerText=comboResult.combo.name;document.getElementById('potential-chips').innerText=comboResult.combo.chips;document.getElementById('potential-mult').innerText=comboResult.combo.mult;document.getElementById('potential-total').innerText=comboResult.combo.chips*comboResult.combo.mult;const buffDetail=document.getElementById('buff-detail');if(comboResult.buffs.length>0){buffDetail.innerText=comboResult.buffs.join(" | ");buffDetail.classList.remove('hidden');}else buffDetail.classList.add('hidden');handContainer.style.opacity=selected.length>0?"1":"0";document.getElementById('current-score').innerText=Math.floor(score).toLocaleString();document.getElementById('target-score').innerText=era.target.toLocaleString();document.getElementById('hands-left').innerText=hands;document.getElementById('discards-left').innerText=discards;document.getElementById('deck-left').innerText=deck.length;}function calculateCombo(){const cards=selected.map(i=>hand[i]);if(cards.length===0)return{combo:{name:'',chips:0,mult:0},buffs:[]};const nameCounts={};cards.forEach(c=>nameCounts[c.name]=(nameCounts[c.name]||0)+1);const counts=Object.values(nameCounts);const maxCount=Math.max(...counts);const nameOfMax=Object.keys(nameCounts).find(k=>nameCounts[k]===maxCount);let combo={name:'QUÂN LẺ',chips:cards.reduce((a,b)=>a+b.rank,0)*5,mult:1};let activeBuffs=[];if(maxCount===5&&nameOfMax==='Tốt')combo={name:'NGŨ TỬ',chips:400,mult:12};else if(maxCount===4)combo={name:'TỨ QUÝ',chips:300,mult:8};else if(maxCount===3)combo={name:'BỘ BA',chips:150,mult:4};else if(maxCount===2&&cards.length===2){if(nameOfMax==='Tướng')combo={name:'ĐÔI TƯỚNG',chips:200,mult:6};else combo={name:'BỘ ĐÔI',chips:40,mult:2};}else if(nameCounts['Xe']&&nameCounts['Pháo']&&nameCounts['Mã']&&cards.length===3){const allSameSuit=cards.every(c=>c.suit===cards[0].suit);if(allSameSuit)combo={name:'XE PHÁO MÃ',chips:120,mult:3};}if(selectedGeneral&&selectedGeneral.buff){const b=selectedGeneral.buff(combo,cards);if(b.chipsAdd)combo.chips+=b.chipsAdd;if(b.multAdd)combo.mult+=b.multAdd;if(b.label)activeBuffs.push(b.label);}if(selectedGeneral&&selectedGeneral.check){const res=selectedGeneral.check(cards);if(res&&res.mult){combo.mult*=res.mult;if(res.label)activeBuffs.push(res.label);}}return{combo,buffs:activeBuffs};}function play(){const comboResult=calculateCombo();score+=(comboResult.combo.chips*comboResult.combo.mult);hands--;selected.sort((a,b)=>b-a).forEach(i=>hand.splice(i,1));selected=[];drawCards();render();if(score>=ERAS[currentEraIdx].target)endRound(true);else if(hands<=0)endRound(false);}function endRound(win){gameWon=win;document.getElementById('msg-overlay').classList.remove('hidden');document.getElementById('msg-title').innerText=win?'THẮNG LỢI':'THẤT BẠI';document.getElementById('msg-desc').innerText=win?'Bạn đã đạt mốc điểm cần thiết!':'Quân đội đã mỏi mệt, hãy thử lại.';}document.getElementById('start-round-btn').onclick=()=>{document.getElementById('general-selection').classList.add('hidden');startNewRound();};document.getElementById('btn-play').onclick=play;document.getElementById('btn-discard').onclick=()=>{if(discards<=0||selected.length===0)return;discards--;selected.sort((a,b)=>b-a).forEach(i=>hand.splice(i,1));selected=[];drawCards();render();};document.getElementById('msg-continue-btn').onclick=()=>{document.getElementById('msg-overlay').classList.add('hidden');if(gameWon){if(currentEraIdx<ERAS.length-1){currentEraIdx++;showGeneralSelection();}else{alert("THỐNG NHẤT SỬ VIỆT!");currentEraIdx=0;document.getElementById('start-menu').classList.remove('hidden');}}else{currentEraIdx=0;document.getElementById('start-menu').classList.remove('hidden');}};</script></body></html>
